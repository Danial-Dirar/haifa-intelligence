# Copy to .env.local and adjust. Never commit .env.local (it is gitignored).

# The Haifa Studio "bridge" (apps/api) that fronts the home GPU.
#   Local dev: the bridge running on your machine.
#   Production: the Cloudflare Tunnel URL that points at the home bridge.
STUDIO_BRIDGE_URL=http://127.0.0.1:8189
